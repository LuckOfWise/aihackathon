<% content_for :title, 'SHINE-MATE — 内なる輝きの可視化' %>

<div class="shine-mate"
     data-controller="face-shine"
     data-face-shine-stage-value="hero"
     data-face-shine-intensity-value="standard">

  <%# Flash overlay (analyzing → result transition) %>
  <div class="shine-mate__flash" data-face-shine-target="flashOverlay" aria-hidden="true"></div>

  <%# Camera capture overlay (getUserMedia) %>
  <div class="shine-camera" data-face-shine-target="cameraOverlay" hidden role="dialog" aria-label="カメラで撮影" aria-modal="true">
    <div class="shine-camera__stage">
      <video class="shine-camera__video"
             data-face-shine-target="cameraVideo"
             playsinline
             muted
             autoplay></video>
      <div class="shine-camera__reticle" aria-hidden="true"></div>
    </div>
    <div class="shine-camera__controls">
      <button type="button" class="shine-camera__close"
              data-action="click->face-shine#closeCamera"
              aria-label="閉じる">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" aria-hidden="true">
          <path d="M6 6l12 12M18 6L6 18"/>
        </svg>
      </button>
      <button type="button" class="shine-camera__shutter"
              data-action="click->face-shine#capturePhoto"
              aria-label="撮影">
        <span class="shine-camera__shutter-ring" aria-hidden="true"></span>
        <span class="shine-camera__shutter-dot" aria-hidden="true"></span>
      </button>
      <div class="shine-camera__spacer" aria-hidden="true"></div>
    </div>
  </div>

  <%# ───────────── STAGE: hero ───────────── %>
  <section class="shine-hero" data-face-shine-target="stageHero">
    <%# Drift particles %>
    <div class="shine-hero__particles" aria-hidden="true">
      <% 24.times do |i| %>
        <span class="shine-hero__particle" style="left:<%= (i*37)%100 %>%;top:<%= (i*53)%100 %>%;animation-delay:<%= (i*0.2).round(1) %>s;animation-duration:<%= 6+(i%5) %>s;opacity:<%= ((0.3 + (i%4)*0.15)*100).round / 100.0 %>"></span>
      <% end %>
    </div>

    <div class="shine-hero__body">
      <header class="shine-hero__header">
        <div class="shine-hero__spec shine-hero__spec--gold">
          <span class="shine-diamond" aria-hidden="true"></span>
          SHINE-MATE&nbsp;&nbsp;·&nbsp;&nbsp;EST. 2026
        </div>
        <div class="shine-hero__spec shine-hero__spec--mute">
          ALL-JAPAN AI HACKATHON · OFFICIAL ENTRY №073
        </div>
      </header>

      <div class="shine-hero__center">
        <p class="shine-hero__jp-sub">其ノ瞳ハ、未ダ磨カレザル</p>
        <h1 class="shine-hero__headline" aria-label="Shine from 内側">
          <em class="shine-hero__headline-em">Shine</em><br>
          from<br>
          <span class="shine-hero__headline-jp">内側</span>
        </h1>
        <p class="shine-hero__lede">
          くすんだ日常の一枚を、<br>
          ダイヤモンドの輝きへ。<br>
          AIが、あなたの「未だ磨かれざる魅力」を<br>
          発掘し、発光させます。
        </p>
      </div>

      <footer class="shine-hero__footer">
        <button class="btn-gold shine-hero__cta"
                data-action="click->face-shine#gotoUpload">
          写真をアップロードして始める →
        </button>

        <ol class="shine-hero__steps" aria-label="利用の流れ">
          <li class="shine-hero__step">
            <span class="shine-hero__step-num">01</span>
            <span class="shine-hero__step-label">写真を上げる</span>
          </li>
          <li class="shine-hero__step">
            <span class="shine-hero__step-num">02</span>
            <span class="shine-hero__step-label">AI が瞳と歯を解析</span>
          </li>
          <li class="shine-hero__step">
            <span class="shine-hero__step-num">03</span>
            <span class="shine-hero__step-label">輝き指数と鑑定書が出る</span>
          </li>
        </ol>

        <div class="shine-hero__meta">
          <span>v0.9.3 · BETA</span>
          <span>POWERED BY CLAUDE</span>
        </div>
      </footer>
    </div>
  </section>

  <%# ───────────── STAGE: upload ───────────── %>
  <section class="shine-upload" data-face-shine-target="stageUpload" hidden>
    <div class="shine-upload__nav">
      <button class="shine-upload__back" aria-label="戻る"
              data-action="click->face-shine#gotoHero">
        <svg width="9" height="14" viewBox="0 0 9 14" fill="none" aria-hidden="true">
          <path d="M8 1L1 7l7 6" stroke="currentColor" stroke-width="1.2" />
        </svg>
      </button>
      <span class="shine-spec shine-spec--mute">01 / 03 · UPLOAD</span>
      <span class="shine-diamond" aria-hidden="true"></span>
    </div>

    <div class="shine-upload__body">
      <h2 class="shine-upload__title">原石を、<br>差し出してください。</h2>
      <p class="shine-upload__desc">
        顔がはっきりと写った、自然光下の一枚を推奨します。<br>
        解析時間：約 12 秒。
      </p>

      <label class="shine-upload__dropzone" for="shine-file-input">
        <span class="shine-upload__corner shine-upload__corner--tl" aria-hidden="true"></span>
        <span class="shine-upload__corner shine-upload__corner--tr" aria-hidden="true"></span>
        <span class="shine-upload__corner shine-upload__corner--bl" aria-hidden="true"></span>
        <span class="shine-upload__corner shine-upload__corner--br" aria-hidden="true"></span>
        <span class="shine-upload__icon-ring" aria-hidden="true">
          <svg width="22" height="22" viewBox="0 0 22 22" fill="none" aria-hidden="true">
            <path d="M11 2v14m0-14L5 8m6-6l6 6M3 18h16" stroke="var(--shine-gold)" stroke-width="1" />
          </svg>
        </span>
        <span class="shine-upload__dropzone-label">タップして写真を選ぶ</span>
        <span class="shine-spec shine-spec--mute">JPG · PNG · HEIC · ≤ 12MB</span>
        <input
          id="shine-file-input"
          type="file"
          accept="image/png,image/jpeg,image/webp"
          class="shine-upload__file-input"
          data-face-shine-target="fileInput"
          data-action="change->face-shine#onFileChange"
          aria-label="写真ファイルを選択">
      </label>

      <div class="shine-upload__hints" role="list">
        <div class="shine-upload__hint" role="listitem">
          <span class="shine-upload__hint-jp">明所</span>
          <span class="shine-spec shine-spec--mute">Bright</span>
        </div>
        <div class="shine-upload__hint" role="listitem">
          <span class="shine-upload__hint-jp">正面</span>
          <span class="shine-spec shine-spec--mute">Front</span>
        </div>
        <div class="shine-upload__hint" role="listitem">
          <span class="shine-upload__hint-jp">素顔</span>
          <span class="shine-spec shine-spec--mute">Bare</span>
        </div>
      </div>

      <button type="button" class="shine-upload__camera-link"
              data-action="click->face-shine#openCamera">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M14.5 4h-5L7 7H4a2 2 0 0 0-2 2v9a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2h-3l-2.5-3z"/>
          <circle cx="12" cy="13" r="3"/>
        </svg>
        <span>その場で撮影する</span>
      </button>

      <p class="shine-upload__error" data-face-shine-target="errorMessage" hidden role="alert"></p>
    </div>
  </section>

  <%# ───────────── STAGE: analyzing ───────────── %>
  <section class="shine-analyzing" data-face-shine-target="stageAnalyzing" hidden aria-live="polite">
    <div class="shine-analyzing__nav">
      <div style="width:34px"></div>
      <span class="shine-spec shine-spec--mute">02 / 03 · ANALYZING</span>
      <span class="shine-diamond" aria-hidden="true"></span>
    </div>

    <div class="shine-analyzing__body">
      <div class="shine-analyzing__canvas-wrap">
        <%# Original image (dimmed) %>
        <img class="shine-analyzing__img" data-face-shine-target="analyzingImg" alt="" aria-hidden="true">
        <%# SVG overlay (face mesh + bbox + scan) %>
        <svg class="shine-analyzing__overlay-svg"
             viewBox="0 0 320 400"
             preserveAspectRatio="xMidYMid slice"
             aria-hidden="true"
             data-face-shine-target="overlaySvg">
          <defs>
            <filter id="ai-glow">
              <feGaussianBlur stdDeviation="1.2" />
              <feMerge>
                <feMergeNode />
                <feMergeNode in="SourceGraphic" />
              </feMerge>
            </filter>
          </defs>
          <g class="shine-analyzing__mesh-edges" data-face-shine-target="meshEdges" opacity="0" filter="url(#ai-glow)"></g>
          <g class="shine-analyzing__mesh-dots" data-face-shine-target="meshDots" opacity="0"></g>
          <g class="shine-analyzing__bbox-group" data-face-shine-target="bboxGroup" opacity="0"></g>
          <g class="shine-analyzing__reticle-group" data-face-shine-target="reticleGroup" opacity="0"></g>
          <g class="shine-analyzing__ticks" data-face-shine-target="tickGroup" opacity="0"></g>
        </svg>
        <%# HTML labels %>
        <div class="shine-analyzing__labels" data-face-shine-target="overlayLabels" aria-hidden="true" style="opacity:0">
          <span class="shine-analyzing__label shine-analyzing__label--iris-l">IRIS_L · 0.94 ▲12%</span>
          <span class="shine-analyzing__label shine-analyzing__label--iris-r">IRIS_R · 0.96 ▲14%</span>
          <span class="shine-analyzing__label shine-analyzing__label--dent">DENTITION · 0.88 ▲ENAMEL</span>
        </div>
        <%# Scan line %>
        <div class="shine-analyzing__scan" data-face-shine-target="scanLine" aria-hidden="true"></div>
        <%# AI pulse tint %>
        <div class="shine-analyzing__ai-pulse" aria-hidden="true"></div>
        <%# Frame corners %>
        <div class="shine-analyzing__corners" aria-hidden="true">
          <span class="shine-analyzing__corner shine-analyzing__corner--tl"></span>
          <span class="shine-analyzing__corner shine-analyzing__corner--tr"></span>
          <span class="shine-analyzing__corner shine-analyzing__corner--bl"></span>
          <span class="shine-analyzing__corner shine-analyzing__corner--br"></span>
        </div>
      </div>

      <div class="shine-analyzing__info">
        <p class="shine-analyzing__headline">魅力を、解析中。</p>
        <div class="shine-analyzing__pct mono" data-face-shine-target="progressPct" aria-live="polite">
          <span data-face-shine-target="progressNum">00</span><span class="shine-analyzing__pct-unit">%</span>
        </div>
      </div>

      <div class="shine-analyzing__progress-bar" role="progressbar" aria-valuenow="0" aria-valuemin="0" aria-valuemax="100" data-face-shine-target="progressBar">
        <div class="shine-analyzing__progress-fill" data-face-shine-target="progressFill"></div>
      </div>

      <div class="shine-analyzing__log mono" data-face-shine-target="logPanel" aria-live="polite" aria-atomic="false">
      </div>
    </div>
  </section>

  <%# ───────────── STAGE: result ───────────── %>
  <section class="shine-result" data-face-shine-target="stageResult" hidden>
    <div class="shine-result__nav">
      <button class="shine-result__back" aria-label="戻る"
              data-action="click->face-shine#gotoUpload">
        <svg width="9" height="14" viewBox="0 0 9 14" fill="none" aria-hidden="true">
          <path d="M8 1L1 7l7 6" stroke="currentColor" stroke-width="1.2" />
        </svg>
      </button>
      <span class="shine-spec shine-spec--mute">03 / 03 · VERDICT</span>
      <span class="shine-diamond" aria-hidden="true"></span>
    </div>

    <div class="shine-result__body">
      <div class="shine-result__eyebrow">
        <span class="shine-diamond" aria-hidden="true"></span>
        SHINE INDEX · + 38.4 PT
      </div>
      <h2 class="shine-result__headline">
        発光、完了。<br>
        <em class="shine-result__headline-en">Behold.</em>
      </h2>

      <%# Before/After slider %>
      <div class="shine-result__slider-wrap"
           data-controller="ba-slider"
           role="group"
           aria-label="Before / After 比較">
        <div class="shine-result__after" data-ba-slider-target="after">
          <canvas class="shine-result__canvas" data-face-shine-target="resultCanvas" aria-label="加工後の画像"></canvas>
        </div>
        <div class="shine-result__before" data-ba-slider-target="before">
          <img class="shine-result__before-img" data-face-shine-target="beforeImg" alt="加工前の画像">
        </div>
        <div class="shine-result__divider" data-ba-slider-target="divider">
          <div class="shine-result__handle" aria-label="スライダー">
            <svg width="14" height="10" viewBox="0 0 14 10" fill="none" aria-hidden="true">
              <path d="M5 1L1 5l4 4M9 1l4 4-4 4" stroke="var(--shine-gold)" stroke-width="1.2" stroke-linecap="round" />
            </svg>
          </div>
        </div>
        <div class="shine-result__shimmer-layer" data-ba-slider-target="shimmer" aria-hidden="true">
          <% 14.times do |i| %>
            <span class="shine-result__shimmer-particle"
                  style="left:<%= (i*23)%100 %>%;top:<%= (i*17)%100 %>%;animation-delay:<%= ((i%5)*0.15).round(2) %>s;animation-duration:<%= (1.6+(i%3)*0.4).round(1) %>s">
            </span>
          <% end %>
        </div>
        <div class="shine-result__label-before mono" data-ba-slider-target="labelBefore">◯ BEFORE</div>
        <div class="shine-result__label-after mono" data-ba-slider-target="labelAfter">★ AFTER</div>
      </div>

      <%# Metrics %>
      <div class="shine-result__metrics" role="list">
        <div class="shine-result__metric" role="listitem">
          <div class="shine-result__metric-val mono" data-face-shine-target="metricEye">+12%</div>
          <div class="shine-spec shine-spec--mute shine-result__metric-key">EYE LUMINANCE</div>
          <div class="shine-result__metric-jp">瞳の輝き</div>
        </div>
        <div class="shine-result__metric" role="listitem">
          <div class="shine-result__metric-val mono" data-face-shine-target="metricEnamel">+18%</div>
          <div class="shine-spec shine-spec--mute shine-result__metric-key">ENAMEL CHROMA</div>
          <div class="shine-result__metric-jp">歯の白さ</div>
        </div>
        <div class="shine-result__metric" role="listitem">
          <div class="shine-result__metric-val mono" data-face-shine-target="metricAttract">+38.4</div>
          <div class="shine-spec shine-spec--mute shine-result__metric-key">ATTRACT INDEX</div>
          <div class="shine-result__metric-jp">魅力指数</div>
        </div>
      </div>

      <%# Intensity selector %>
      <div class="shine-result__intensity"
           data-controller="intensity-selector"
           data-intensity-selector-selected-value="standard"
           data-action="intensity-selector:change->face-shine#onIntensityChange"
           role="group"
           aria-label="輝き強度">
        <button class="shine-result__intensity-btn"
                data-intensity-selector-target="option"
                data-intensity="subtle"
                data-action="click->intensity-selector#select"
                aria-pressed="false">
          控えめ
        </button>
        <button class="shine-result__intensity-btn is-active"
                data-intensity-selector-target="option"
                data-intensity="standard"
                data-action="click->intensity-selector#select"
                aria-pressed="true">
          標準
        </button>
        <button class="shine-result__intensity-btn"
                data-intensity-selector-target="option"
                data-intensity="sparkle"
                data-action="click->intensity-selector#select"
                aria-pressed="false">
          キラキラ ✦
        </button>
      </div>

      <button class="btn-gold shine-result__cta"
              data-action="click->face-shine#gotoVerdict">
        AI に紹介文を書いてもらう →
      </button>

      <button class="shine-result__download"
              data-action="click->face-shine#download"
              data-face-shine-target="downloadButton">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4" />
          <polyline points="7 10 12 15 17 10" />
          <line x1="12" y1="15" x2="12" y2="3" />
        </svg>
        ダウンロード
      </button>
    </div>
  </section>

  <%# ───────────── STAGE: verdict ───────────── %>
  <section class="shine-verdict" data-face-shine-target="stageVerdict" hidden>
    <div class="shine-verdict__nav">
      <button class="shine-verdict__back" aria-label="戻る"
              data-action="click->face-shine#gotoResult">
        <svg width="9" height="14" viewBox="0 0 9 14" fill="none" aria-hidden="true">
          <path d="M8 1L1 7l7 6" stroke="currentColor" stroke-width="1.2" />
        </svg>
      </button>
      <span class="shine-spec shine-spec--mute">PROFILE INTRO</span>
      <span class="shine-diamond" aria-hidden="true"></span>
    </div>

    <div class="shine-verdict__body">
      <header class="shine-verdict__heading">
        <p class="shine-verdict__eyebrow shine-spec shine-spec--gold">
          <span class="shine-diamond" aria-hidden="true"></span>
          AI が考えたあなたの紹介文
        </p>
        <h1 class="shine-verdict__title">マッチングアプリで、<br>そのまま使える 1 文。</h1>
        <p class="shine-verdict__lede">写真の雰囲気から、Claude があなた自身の言葉として書き起こしました。気に入ったらコピーしてどうぞ。</p>
      </header>

      <div class="shine-verdict__intro-card">
        <p class="shine-verdict__intro" data-face-shine-target="commentDisplay" aria-live="polite"></p>
        <button type="button"
                class="shine-verdict__copy"
                data-action="click->face-shine#copyComment"
                data-face-shine-target="copyButton"
                aria-label="紹介文をコピー">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect>
            <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path>
          </svg>
          <span data-face-shine-target="copyLabel">コピー</span>
        </button>
      </div>

      <div class="shine-verdict__score shine-spec shine-spec--mute" data-face-shine-target="scoreDisplay"></div>

      <button class="btn-gold shine-verdict__cta"
              data-action="click->face-shine#gotoMatch">
        マッチング画面で見る →
      </button>
    </div>
  </section>

  <%# ───────────── STAGE: match ───────────── %>
  <section class="shine-match" data-face-shine-target="stageMatch" hidden>
    <div class="shine-match__nav">
      <button class="shine-match__back" aria-label="戻る"
              data-action="click->face-shine#gotoVerdict">
        <svg width="9" height="14" viewBox="0 0 9 14" fill="none" aria-hidden="true">
          <path d="M8 1L1 7l7 6" stroke="currentColor" stroke-width="1.2" />
        </svg>
      </button>
      <span class="shine-spec shine-spec--mute">· · PROJECTED IMPACT</span>
      <span class="shine-diamond" aria-hidden="true"></span>
    </div>

    <div class="shine-match__body">
      <div class="shine-match__eyebrow">
        <span class="shine-diamond" aria-hidden="true"></span>
        FORECAST · BASED ON SHINE INDEX
      </div>
      <h2 class="shine-match__headline">
        磨かれた輝きは、<br>
        数字に宿る。
      </h2>
      <p class="shine-match__lede">
        いまの発光量を現実の振る舞いに換算すると、<br>
        おそらく、こう映ります。
      </p>

      <figure class="shine-match__figure">
        <div class="shine-match__figure-frame">
          <canvas class="shine-match__photo" data-face-shine-target="matchCanvas" aria-label="加工後の画像"></canvas>
          <span class="shine-match__figure-corner shine-match__figure-corner--tl" aria-hidden="true"></span>
          <span class="shine-match__figure-corner shine-match__figure-corner--tr" aria-hidden="true"></span>
          <span class="shine-match__figure-corner shine-match__figure-corner--bl" aria-hidden="true"></span>
          <span class="shine-match__figure-corner shine-match__figure-corner--br" aria-hidden="true"></span>
        </div>
        <figcaption class="shine-match__figcaption shine-spec shine-spec--mute">
          REFERENCE · INTENSITY STANDARD
        </figcaption>
      </figure>

      <dl class="shine-match__specs" role="list">
        <div class="shine-match__spec" role="listitem">
          <dt class="shine-match__spec-key">視線滞留</dt>
          <dd class="shine-match__spec-val">+0.42<span class="shine-match__spec-unit">sec</span></dd>
        </div>
        <div class="shine-match__spec" role="listitem">
          <dt class="shine-match__spec-key">スクロール停止率</dt>
          <dd class="shine-match__spec-val">×1.6</dd>
        </div>
        <div class="shine-match__spec" role="listitem">
          <dt class="shine-match__spec-key">既読率</dt>
          <dd class="shine-match__spec-val">+18<span class="shine-match__spec-unit">%</span></dd>
        </div>
        <div class="shine-match__spec" role="listitem">
          <dt class="shine-match__spec-key">第一印象の温度</dt>
          <dd class="shine-match__spec-val">+2.1<span class="shine-match__spec-unit">℃</span></dd>
        </div>
        <div class="shine-match__spec" role="listitem">
          <dt class="shine-match__spec-key">検索結果ホバー</dt>
          <dd class="shine-match__spec-val">×2.3</dd>
        </div>
      </dl>

      <p class="shine-match__disclaimer">
        ※ SHINE INDEX スコアに基づく推定値。実測値ではありません。
      </p>

      <button class="btn-ghost shine-match__restart"
              data-action="click->face-shine#gotoHero">
        別の写真を試す
      </button>
    </div>
  </section>
</div>
