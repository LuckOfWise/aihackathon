<% content_for :title, 'Items' %>

<%= render Ui::PageComponent.new(title: 'Items', width: :wide) do |page| %>
  <% page.with_lede do %>
    汎用リソース。当日テーマに合わせて <code>Item</code> をリネームすれば即使える。
  <% end %>
  <% page.with_actions do %>
    <%= link_to new_item_path, class: 'button', data: { variant: 'primary' } do %>
      <%= render Ui::IconComponent.new(name: 'plus', size: 16) %>
      新規作成
    <% end %>
  <% end %>

  <% if @items.any? %>
    <div class="items__list-head items__list">
      <span>タイトル</span>
      <span>抜粋</span>
      <span>ステータス</span>
      <span>更新</span>
      <span></span>
    </div>
    <% @items.each do |item| %>
      <%= link_to item_path(item), class: 'dense-list__row items__list' do %>
        <span class="dense-list__title"><%= item.title.presence || '(無題)' %></span>
        <span class="dense-list__excerpt"><%= item.excerpt %></span>
        <%= render Ui::BadgeComponent.new(variant: status_variant(item.status), with_dot: true) do %>
          <%= item.status.text %>
        <% end %>
        <span class="dense-list__mono"><%= l(item.updated_at, format: :short) %></span>
        <span style="color: var(--color-text-muted);">
          <%= render Ui::IconComponent.new(name: 'chevron-right', size: 16) %>
        </span>
      <% end %>
    <% end %>
  <% else %>
    <%= render Ui::EmptyStateComponent.new(title: 'まだアイテムがありません', hint: '最初のアイテムを作成してください') do |c| %>
      <% c.with_action do %>
        <%= link_to '作成する', new_item_path, class: 'button', data: { variant: 'primary' } %>
      <% end %>
    <% end %>
  <% end %>
<% end %>
