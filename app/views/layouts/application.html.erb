<!DOCTYPE html>
<html lang="ja">
  <head>
    <title><%= content_for(:title) || "Aihackathon" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Aihackathon">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="anonymous">
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;1,400;1,500&family=Shippori+Mincho:wght@400;500;600&family=Inter:wght@400;500;600;700&family=Noto+Sans+JP:wght@400;500;600&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
    <%= stylesheet_link_tag :app %>
    <%= vite_client_tag %>
    <%= vite_javascript_tag 'application' %>
  </head>

  <body>
    <div class="layout">
      <header class="layout__header">
        <%= render Ui::NavbarComponent.new do |c| %>
          <% c.with_brand do %>
            <%= link_to root_path, class: 'navbar__brand' do %>
              <%= render Ui::IconComponent.new(name: 'sparkles', size: 18) %>
              Aihackathon
            <% end %>
          <% end %>
        <% end %>
      </header>

      <main class="layout__main">
        <% if notice.present? %>
          <%= render Ui::AlertComponent.new(variant: :notice) { notice } %>
        <% end %>
        <% if alert.present? %>
          <%= render Ui::AlertComponent.new(variant: :alert) { alert } %>
        <% end %>

        <%= yield %>
      </main>

      <footer class="layout__footer">
        Aihackathon · Rails 8 + Hotwire + ActiveAgent
      </footer>
    </div>
  </body>
</html>
