#!/usr/bin/env bash
set -euo pipefail

START_PORT="${1:-3130}"

port=$START_PORT
max_port=$((START_PORT + 100))
while lsof -iTCP:"$port" -sTCP:LISTEN -t >/dev/null 2>&1; do
  port=$((port + 1))
  if [ "$port" -gt "$max_port" ]; then
    echo "Error: No available port found in range $START_PORT-$max_port" >&2
    exit 1
  fi
done

echo "$port"
